{
	"$schema": "https://biomejs.dev/schemas/2.4.14/schema.json",
	"files": {
		"includes": [
			"**/packages/**/*/src/**",
			"**/apps/**/*/src/**",
			"!**/node_modules/**",
			"!**/dist/**"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"trailingCommas": "all",
			"semicolons": "always"
		}
	}
}
