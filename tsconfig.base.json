{
	"compilerOptions": {
		"module":           "esnext",
		"moduleResolution": "bundler",
		"target":           "esnext",
		"types":            ["node"],
		"strict":                     true,
		"sourceMap":                  true,
		"declaration":                true,
		"declarationMap":             true,
		"verbatimModuleSyntax":       true,
		"isolatedModules":            true,
		"noUncheckedIndexedAccess":   true,
		"exactOptionalPropertyTypes": true,
		"skipLibCheck":               true,
		"ignoreDeprecations":         "6.0"
	}
}
