  "recipes": {
    "basic-auth": { "when": "sign up + log in with email/password", "packages": ["auth", "core", "events", "store"], "invariants": ["jwt-secret-from-env", "rate-limit-default-on"] },
    "oauth": { "when": "social login (Google/GitHub)", "packages": ["auth", "config", "core", "store"], "invariants": ["jwt-secret-from-env"] },
    "route-guard": { "when": "gate a route behind login", "packages": ["auth"], "invariants": [], "note": "use requireAuth middleware from @fonderie/auth on the protected route" },
