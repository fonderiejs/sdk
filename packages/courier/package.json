{
	"name": "@fonderie/courier",
	"version": "1.0.0",
	"description": "Transactional messaging for SaaS — multi-channel delivery (email, SMS, push) with FS or DB templates, per-message-type channel routing, and a persistent message log.",
	"keywords": [
		"fonderie-js",
		"email",
		"sms",
		"transactional",
		"messaging",
		"notifications",
		"nodemailer",
		"templates",
		"saas",
		"typescript"
	],
	"license": "MIT",
	"type": "module",
	"engines": {
		"node": ">=20"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		},
		"./types": {
			"types": "./dist/types.d.ts",
			"import": "./dist/types.js",
			"require": "./dist/types.cjs"
		},
		"./migrations": {
			"types": "./dist/migrations/index.d.ts",
			"import": "./dist/migrations/index.js"
		}
	},
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"scripts": {
		"build": "tsup && tsup --config tsup.migrations.ts",
		"dev": "tsup --watch",
		"typecheck": "tsc --noEmit",
		"test": "tsx --test src/__tests__/*.test.ts",
		"lint": "biome lint src",
		"format": "biome format --write src",
		"check": "biome check --write src"
	},
	"dependencies": {
		"nodemailer": "^8.0.7"
	},
	"peerDependencies": {
		"@fonderie/core": "^0.1.0",
		"@fonderie/store": "^0.1.0",
		"@fonderie/events": "^1.0.0"
	},
	"peerDependenciesMeta": {
		"@fonderie/store": {
			"optional": true
		},
		"@fonderie/events": {
			"optional": true
		}
	},
	"devDependencies": {
		"@fonderie/core": "../core",
		"@fonderie/store": "../store",
		"@fonderie/events": "../events",
		"@types/node": "^25.6.0",
		"@types/nodemailer": "^8.0.0",
		"tsup": "^8.5.1",
		"tsx": "^4.21.0",
		"typescript": "^6.0.3"
	},
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"dist",
		"LICENSE",
		"README.md"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/fonderie-js/sdk.git",
		"directory": "packages/courier"
	},
	"homepage": "https://github.com/fonderie-js/sdk/tree/main/packages/courier#readme",
	"bugs": {
		"url": "https://github.com/fonderie-js/sdk/issues"
	}
}
