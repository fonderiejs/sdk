{
	"name": "@fonderie-js/customers",
	"version": "0.0.1",
	"description": "Workspace-scoped customer records — individuals and businesses with multiple emails, phones, addresses, notes, and tags.",
	"keywords": [
		"fonderie-js",
		"customers",
		"saas",
		"typescript"
	],
	"license": "MIT",
	"type": "module",
	"engines": {
		"node": ">=20"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		},
		"./types": {
			"types": "./dist/types.d.ts",
			"import": "./dist/types.js",
			"require": "./dist/types.cjs"
		},
		"./migrations": {
			"types": "./dist/migrations/index.d.ts",
			"import": "./dist/migrations/index.js"
		}
	},
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"scripts": {
		"build": "tsup && node -e \"require('node:fs').cpSync('src/migrations/sql', 'dist/migrations/sql', {recursive:true})\"",
		"dev": "tsup --watch",
		"typecheck": "tsc --noEmit",
		"test": "tsx --test src/__tests__/*.test.ts",
		"lint": "biome lint src",
		"format": "biome format --write src",
		"check": "biome check --write src"
	},
	"peerDependencies": {
		"@fonderie-js/core": "^0.0.1",
		"@fonderie-js/events": "^0.0.1",
		"@fonderie-js/store": "^0.0.1",
		"@fonderie-js/workspaces": "^0.0.1"
	},
	"peerDependenciesMeta": {
		"@fonderie-js/events": {
			"optional": true
		},
		"@fonderie-js/workspaces": {
			"optional": true
		}
	},
	"devDependencies": {
		"@fonderie-js/core": "../core",
		"@fonderie-js/events": "../events",
		"@fonderie-js/store": "../store",
		"@fonderie-js/workspaces": "../workspaces",
		"@types/node": "^25.6.0",
		"tsup": "^8.5.1",
		"tsx": "^4.21.0",
		"typescript": "^6.0.3"
	},
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"dist",
		"LICENSE",
		"README.md"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/fonderie-js/sdk.git",
		"directory": "packages/customers"
	},
	"homepage": "https://github.com/fonderie-js/sdk/tree/main/packages/customers#readme",
	"bugs": {
		"url": "https://github.com/fonderie-js/sdk/issues"
	}
}
