{
	"name": "@fonderie/auth",
	"version": "1.1.1",
	"description": "Drop-in auth for SaaS — email/password, phone OTP, Google OAuth, stateless JWT sessions, TOTP-based MFA with backup codes, and self-service password recovery.",
	"keywords": [
		"fonderie-js",
		"auth",
		"authentication",
		"jwt",
		"oauth",
		"mfa",
		"totp",
		"otp",
		"sessions",
		"saas",
		"typescript"
	],
	"license": "MIT",
	"type": "module",
	"engines": {
		"node": ">=20"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		},
		"./types": {
			"types": "./dist/types.d.ts",
			"import": "./dist/types.js",
			"require": "./dist/types.cjs"
		},
		"./middleware": {
			"types": "./dist/middlewares/index.d.ts",
			"import": "./dist/middlewares/index.js",
			"require": "./dist/middlewares/index.cjs"
		},
		"./migrations": {
			"types": "./dist/migrations/index.d.ts",
			"import": "./dist/migrations/index.js"
		}
	},
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"scripts": {
		"build": "tsup && tsup --config tsup.migrations.ts",
		"dev": "tsup --watch",
		"typecheck": "tsc --noEmit",
		"test": "tsx --test src/__tests__/*.test.ts",
		"lint": "biome lint src",
		"format": "biome format --write src",
		"check": "biome check --write src"
	},
	"dependencies": {
		"bcryptjs": "^3.0.3",
		"jsonwebtoken": "^9.0.3",
		"qrcode": "^1.5.4",
		"zod": "^4.4.3"
	},
	"peerDependencies": {
		"@fonderie/core": "^0.1.1",
		"@fonderie/events": "^1.0.1",
		"@fonderie/store": "^0.1.1"
	},
	"peerDependenciesMeta": {
		"@fonderie/events": {
			"optional": true
		}
	},
	"devDependencies": {
		"@fonderie/core": "../core",
		"@fonderie/events": "../events",
		"@fonderie/store": "../store",
		"@types/bcryptjs": "^2.4.6",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/node": "^25.6.0",
		"@types/qrcode": "^1.5.6",
		"tsup": "^8.5.1",
		"tsx": "^4.21.0",
		"typescript": "^6.0.3"
	},
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"dist",
		"LICENSE",
		"README.md"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/fonderie-js/sdk.git",
		"directory": "packages/auth"
	},
	"homepage": "https://github.com/fonderie-js/sdk/tree/main/packages/auth#readme",
	"bugs": {
		"url": "https://github.com/fonderie-js/sdk/issues"
	}
}
