{
	"name": "@fonderie-js/auth",
	"version": "0.0.1",
	"description": "Authentication — JWT, sessions, OAuth, MFA, and password recovery",
	"license": "UNLICENSED",
	"type": "module",
	"engines": { "node": ">=20" },
	"exports": {
		".": {
			"types":   "./dist/index.d.ts",
			"import":  "./dist/index.js",
			"require": "./dist/index.cjs"
		},
		"./types": {
			"types":   "./dist/types.d.ts",
			"import":  "./dist/types.js",
			"require": "./dist/types.cjs"
		},
		"./middleware": {
			"types":   "./dist/middlewares/index.d.ts",
			"import":  "./dist/middlewares/index.js",
			"require": "./dist/middlewares/index.cjs"
		},
		"./migrations": {
			"types":   "./dist/migrations/index.d.ts",
			"import":  "./dist/migrations/index.js",
			"require": "./dist/migrations/index.cjs"
		}
	},
	"main":   "./dist/index.cjs",
	"module": "./dist/index.js",
	"types":  "./dist/index.d.ts",
	"scripts": {
		"build":     "tsup && node -e \"require('node:fs').cpSync('src/migrations/sql', 'dist/migrations/sql', {recursive:true})\"",
		"dev":       "tsup --watch",
		"typecheck": "tsc --noEmit",
		"test":      "tsx --test src/__tests__/*.test.ts",
		"lint":      "biome lint src",
		"format":    "biome format --write src",
		"check":     "biome check --write src"
	},
	"dependencies": {
		"bcryptjs":     "^3.0.3",
		"jsonwebtoken": "^9.0.3"
	},
	"peerDependencies": {
		"@fonderie-js/core":  "^0.0.1",
		"@fonderie-js/store": "^0.0.1"
	},
	"devDependencies": {
		"@fonderie-js/core":    "../core",
		"@fonderie-js/store":   "../store",
		"@types/bcryptjs":      "^2.4.6",
		"@types/jsonwebtoken":  "^9.0.10",
		"@types/node":          "^25.6.0",
		"tsup":                 "^8.5.1",
		"tsx":                  "^4.21.0",
		"typescript":           "^6.0.3"
	}
}
