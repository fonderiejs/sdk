{
	"name": "@fonderie/config",
	"version": "2.0.0",
	"description": "DB-backed feature flags and remote config — per-environment overrides, TTL-based hot reload, and a typed getConfig helper usable inside any middleware.",
	"keywords": [
		"fonderie-js",
		"feature-flags",
		"remote-config",
		"runtime-config",
		"saas",
		"typescript"
	],
	"license": "MIT",
	"type": "module",
	"engines": {
		"node": ">=20"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		},
		"./types": {
			"types": "./dist/types.d.ts",
			"import": "./dist/types.js",
			"require": "./dist/types.cjs"
		},
		"./middleware": {
			"types": "./dist/middlewares/index.d.ts",
			"import": "./dist/middlewares/index.js",
			"require": "./dist/middlewares/index.cjs"
		},
		"./migrations": {
			"types": "./dist/migrations/index.d.ts",
			"import": "./dist/migrations/index.js"
		}
	},
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"scripts": {
		"build": "tsup && tsup --config tsup.migrations.ts",
		"dev": "tsup --watch",
		"typecheck": "tsc --noEmit",
		"test": "tsx --test src/__tests__/*.test.ts",
		"lint": "biome lint src",
		"format": "biome format --write src",
		"check": "biome check --write src"
	},
	"peerDependencies": {
		"@fonderie/core": "^0.2.0",
		"@fonderie/store": "^0.1.1"
	},
	"devDependencies": {
		"@fonderie/core": "../core",
		"@fonderie/store": "../store",
		"@types/node": "^25.6.0",
		"tsup": "^8.5.1",
		"tsx": "^4.21.0",
		"typescript": "^6.0.3"
	},
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"dist",
		"brain",
		"LICENSE",
		"README.md"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/fonderiejs/sdk.git",
		"directory": "packages/config"
	},
	"homepage": "https://github.com/fonderiejs/sdk/tree/main/packages/config#readme",
	"bugs": {
		"url": "https://github.com/fonderiejs/sdk/issues"
	}
}
