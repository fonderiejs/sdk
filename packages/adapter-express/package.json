{
	"name": "@fonderie/adapter-express",
	"version": "3.0.0",
	"description": "Express adapter for fonderie-js — bridge(), adapt(), mount() to use fonderie middleware in native Express routes.",
	"keywords": [
		"fonderie-js",
		"express",
		"adapter",
		"middleware",
		"saas",
		"typescript"
	],
	"license": "MIT",
	"type": "module",
	"engines": {
		"node": ">=20"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"test": "tsx --test src/__tests__/*.test.ts",
		"typecheck": "tsc --noEmit",
		"lint": "biome lint src",
		"format": "biome format --write src",
		"check": "biome check --write src"
	},
	"peerDependencies": {
		"@fonderie/core": "^0.3.0",
		"@fonderie/workspaces": "^3.0.0",
		"@fonderie/permissions": "^3.0.0",
		"@fonderie/billing": "^3.0.0",
		"express": "^4.0.0 || ^5.0.0"
	},
	"peerDependenciesMeta": {
		"@fonderie/workspaces": {
			"optional": true
		},
		"@fonderie/permissions": {
			"optional": true
		},
		"@fonderie/billing": {
			"optional": true
		}
	},
	"devDependencies": {
		"@fonderie/core": "../core",
		"@fonderie/workspaces": "../workspaces",
		"@fonderie/permissions": "../permissions",
		"@fonderie/billing": "../billing",
		"@types/node": "^25.6.0",
		"tsx": "^4.21.0",
		"tsup": "^8.5.1",
		"typescript": "^6.0.3"
	},
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"dist",
		"brain",
		"LICENSE",
		"README.md"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/fonderiejs/sdk.git",
		"directory": "packages/adapter-express"
	},
	"homepage": "https://github.com/fonderiejs/sdk/tree/main/packages/adapter-express#readme",
	"bugs": {
		"url": "https://github.com/fonderiejs/sdk/issues"
	}
}
