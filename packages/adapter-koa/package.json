{
	"name": "@fonderie-js/adapter-koa",
	"version": "1.0.0",
	"description": "Koa adapter for fonderie-js — bridge(), adapt(), mount() to use fonderie middleware in native Koa routes.",
	"keywords": [
		"fonderie-js",
		"koa",
		"adapter",
		"middleware",
		"saas",
		"typescript"
	],
	"license": "MIT",
	"type": "module",
	"engines": {
		"node": ">=20"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"test": "tsx --test src/__tests__/*.test.ts",
		"typecheck": "tsc --noEmit",
		"lint": "biome lint src",
		"format": "biome format --write src",
		"check": "biome check --write src"
	},
	"peerDependencies": {
		"@fonderie-js/core": "^0.1.0",
		"@fonderie-js/workspaces": "^1.0.0",
		"@fonderie-js/permissions": "^1.0.0",
		"@fonderie-js/billing": "^1.0.0",
		"koa": "^2.0.0"
	},
	"peerDependenciesMeta": {
		"@fonderie-js/workspaces": {
			"optional": true
		},
		"@fonderie-js/permissions": {
			"optional": true
		},
		"@fonderie-js/billing": {
			"optional": true
		}
	},
	"devDependencies": {
		"@fonderie-js/core": "../core",
		"@fonderie-js/workspaces": "../workspaces",
		"@fonderie-js/permissions": "../permissions",
		"@fonderie-js/billing": "../billing",
		"koa": "^2.16.1",
		"@types/koa": "^2.15.0",
		"@types/node": "^25.6.0",
		"tsx": "^4.21.0",
		"tsup": "^8.5.1",
		"typescript": "^6.0.3"
	},
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"dist",
		"LICENSE",
		"README.md"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/fonderie-js/sdk.git",
		"directory": "packages/adapter-koa"
	},
	"homepage": "https://github.com/fonderie-js/sdk/tree/main/packages/adapter-koa#readme",
	"bugs": {
		"url": "https://github.com/fonderie-js/sdk/issues"
	}
}
