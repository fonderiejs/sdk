{
	"name": "@fonderie-js/adapter-koa",
	"version": "0.0.1",
	"description": "Koa adapter for fonderie-js — bridge(), adapt(), mount() to use fonderie middleware in native Koa routes.",
	"keywords": ["fonderie-js", "koa", "adapter", "middleware", "saas", "typescript"],
	"license": "UNLICENSED",
	"type": "module",
	"engines": { "node": ">=20" },
	"exports": {
		".": {
			"types":   "./dist/index.d.ts",
			"import":  "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"main":   "./dist/index.cjs",
	"module": "./dist/index.js",
	"types":  "./dist/index.d.ts",
	"scripts": {
		"build":     "tsup",
		"dev":       "tsup --watch",
		"test":      "tsx --test src/__tests__/*.test.ts",
		"typecheck": "tsc --noEmit",
		"lint":      "biome lint src",
		"format":    "biome format --write src",
		"check":     "biome check --write src"
	},
	"peerDependencies": {
		"@fonderie-js/core":        "^0.0.1",
		"@fonderie-js/workspaces":  "^0.0.1",
		"@fonderie-js/permissions": "^0.0.1",
		"@fonderie-js/billing":     "^0.0.1",
		"koa":                      "^2.0.0"
	},
	"peerDependenciesMeta": {
		"@fonderie-js/workspaces":  { "optional": true },
		"@fonderie-js/permissions": { "optional": true },
		"@fonderie-js/billing":     { "optional": true }
	},
	"devDependencies": {
		"@fonderie-js/core":        "../core",
		"@fonderie-js/workspaces":  "../workspaces",
		"@fonderie-js/permissions": "../permissions",
		"@fonderie-js/billing":     "../billing",
		"koa":                      "^2.16.1",
		"@types/koa":               "^2.15.0",
		"@types/node":              "^25.6.0",
		"tsx":                      "^4.21.0",
		"tsup":                     "^8.5.1",
		"typescript":               "^6.0.3"
	}
}
