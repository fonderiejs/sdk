{
	"name": "@fonderie-js/client",
	"version": "0.0.1",
	"description": "Typed HTTP client for the Fonderie API",
	"license": "UNLICENSED",
	"type": "module",
	"engines": {
		"node": ">=20"
	},
	"exports": {
		".": {
			"types":   "./dist/index.d.ts",
			"import":  "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"main":   "./dist/index.cjs",
	"module": "./dist/index.js",
	"types":  "./dist/index.d.ts",
	"scripts": {
		"build":     "tsup",
		"dev":       "tsup --watch",
		"typecheck": "tsc --noEmit"
	},
	"devDependencies": {
		"@types/node": "^25.6.0",
		"tsup":       "^8.5.1",
		"typescript": "^6.0.3"
	}
}
