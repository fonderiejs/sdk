{
	"name": "@fonderie/audit",
	"version": "1.0.1",
	"description": "Workspace-scoped audit log — query fonderie_events for a human-readable activity trail.",
	"keywords": [
		"fonderie-js",
		"audit",
		"events",
		"saas",
		"typescript"
	],
	"license": "MIT",
	"type": "module",
	"engines": {
		"node": ">=20"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"typecheck": "tsc --noEmit",
		"test": "tsx --test src/__tests__/*.test.ts",
		"lint": "biome lint src",
		"format": "biome format --write src",
		"check": "biome check --write src"
	},
	"peerDependencies": {
		"@fonderie/core": "^0.1.1",
		"@fonderie/store": "^0.1.1"
	},
	"devDependencies": {
		"@fonderie/core": "../core",
		"@fonderie/store": "../store",
		"@types/node": "^25.6.0",
		"tsup": "^8.5.1",
		"tsx": "^4.21.0",
		"typescript": "^6.0.3"
	},
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"dist",
		"brain",
		"LICENSE",
		"README.md"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/fonderie-js/sdk.git",
		"directory": "packages/audit"
	},
	"homepage": "https://github.com/fonderie-js/sdk/tree/main/packages/audit#readme",
	"bugs": {
		"url": "https://github.com/fonderie-js/sdk/issues"
	}
}
