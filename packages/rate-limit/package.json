{
	"name": "@fonderie/rate-limit",
	"version": "2.0.0",
	"description": "Distributed rate limiting for @fonderie-js — atomic token bucket over memory, PostgreSQL, or Redis, with standard RateLimit-* headers.",
	"keywords": [
		"fonderie-js",
		"rate-limit",
		"token-bucket",
		"throttle",
		"brute-force",
		"typescript"
	],
	"license": "MIT",
	"type": "module",
	"engines": {
		"node": ">=20"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		},
		"./migrations": {
			"types": "./dist/migrations/index.d.ts",
			"import": "./dist/migrations/index.js"
		}
	},
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"scripts": {
		"build": "tsup && tsup --config tsup.migrations.ts",
		"dev": "tsup --watch",
		"typecheck": "tsc --noEmit",
		"test": "tsx --test src/__tests__/*.test.ts",
		"lint": "biome lint src",
		"format": "biome format --write src",
		"check": "biome check --write src"
	},
	"peerDependencies": {
		"@fonderie/core": "^0.3.0",
		"@fonderie/store": "^0.1.1"
	},
	"peerDependenciesMeta": {
		"@fonderie/store": {
			"optional": true
		}
	},
	"devDependencies": {
		"@fonderie/core": "../core",
		"@fonderie/store": "../store",
		"@types/node": "^25.6.0",
		"tsup": "^8.5.1",
		"tsx": "^4.21.0",
		"typescript": "^6.0.3",
		"pg": "^8.13.3",
		"@types/pg": "^8.11.10",
		"redis": "^4.7.0"
	},
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"dist",
		"brain",
		"LICENSE",
		"README.md"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/fonderiejs/sdk.git",
		"directory": "packages/rate-limit"
	},
	"homepage": "https://github.com/fonderiejs/sdk/tree/main/packages/rate-limit#readme",
	"bugs": {
		"url": "https://github.com/fonderiejs/sdk/issues"
	}
}
