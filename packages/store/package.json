{
	"name": "@fonderie-js/store",
	"version": "0.0.1",
	"description": "Database adapter interface, migration runner, and SQL helpers",
	"license": "UNLICENSED",
	"type": "module",
	"engines": {
		"node": ">=20"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		},
		"./sql": {
			"types": "./dist/sql.d.ts",
			"import": "./dist/sql.js",
			"require": "./dist/sql.cjs"
		},
		"./types": {
			"types": "./dist/types.d.ts",
			"import": "./dist/types.js",
			"require": "./dist/types.cjs"
		},
		"./migrations": {
			"types": "./dist/migrations/index.d.ts",
			"import": "./dist/migrations/index.js"
		}
	},
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"typecheck": "tsc --noEmit",
		"test": "tsx --test src/__tests__/*.test.ts",
		"lint": "biome lint src",
		"format": "biome format --write src",
		"check": "biome check --write src"
	},
	"dependencies": {
		"pg": "^8.20.0"
	},
	"devDependencies": {
		"@types/node": "^25.6.0",
		"@types/pg": "^8.20.0",
		"tsup": "^8.5.1",
		"tsx": "^4.21.0",
		"typescript": "^6.0.3"
	}
}
