{
	"name": "@fonderie/webhooks",
	"version": "1.1.2",
	"description": "Outgoing webhook engine — register endpoints, fan out workspace-scoped events, track delivery, and retry on failure.",
	"keywords": [
		"fonderie-js",
		"webhooks",
		"events",
		"saas",
		"typescript"
	],
	"license": "MIT",
	"type": "module",
	"engines": {
		"node": ">=20"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		},
		"./migrations": {
			"types": "./dist/migrations/index.d.ts",
			"import": "./dist/migrations/index.js"
		}
	},
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"scripts": {
		"build": "tsup && tsup --config tsup.migrations.ts",
		"dev": "tsup --watch",
		"typecheck": "tsc --noEmit",
		"test": "tsx --test src/__tests__/*.test.ts",
		"lint": "biome lint src",
		"format": "biome format --write src",
		"check": "biome check --write src"
	},
	"peerDependencies": {
		"@fonderie/core": "^0.1.1",
		"@fonderie/events": "^1.0.1",
		"@fonderie/store": "^0.1.1"
	},
	"peerDependenciesMeta": {
		"@fonderie/events": {
			"optional": true
		}
	},
	"devDependencies": {
		"@fonderie/core": "../core",
		"@fonderie/events": "../events",
		"@fonderie/store": "../store",
		"@types/node": "^25.6.0",
		"tsup": "^8.5.1",
		"tsx": "^4.21.0",
		"typescript": "^6.0.3"
	},
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"dist",
		"brain",
		"LICENSE",
		"README.md"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/fonderiejs/sdk.git",
		"directory": "packages/webhooks"
	},
	"homepage": "https://github.com/fonderiejs/sdk/tree/main/packages/webhooks#readme",
	"bugs": {
		"url": "https://github.com/fonderiejs/sdk/issues"
	},
	"dependencies": {
		"zod": "^4.4.3"
	}
}
