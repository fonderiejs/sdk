# ── Database ─────────────────────────────────────────────────────
# Local Postgres (see docker-compose.yml or run: createdb fonderie_dev)
DATABASE_URL=postgres://fonderie:fonderie@localhost:5432/fonderie_dev

# ── Auth ─────────────────────────────────────────────────────────
# Must be at least 32 characters
JWT_SECRET=change-me-to-a-random-32-char-secret!!

# ── Email (optional for local dev) ───────────────────────────────
# Leave blank to skip email delivery — courier will log but not send
SMTP_USER=
SMTP_PASS=
# Ethereal free test account: https://ethereal.email
# SMTP_USER=your.ethereal.user@ethereal.email
# SMTP_PASS=yourEtherealPassword

# ── Stripe (optional — billing routes still register, checkout will fail) ──
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_MONTHLY=
STRIPE_STARTER_YEARLY=
STRIPE_PRO_MONTHLY=
STRIPE_PRO_YEARLY=

# ── App ───────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
