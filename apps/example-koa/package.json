{
	"name": "example-koa",
	"version": "1.0.0",
	"description": "Minimal fonderie-js todo app using Koa",
	"type": "module",
	"scripts": {
		"dev": "node --env-file=.env --experimental-strip-types index.ts",
		"setup": "cp -n .env.example .env || true",
		"test": "tsx --test *.test.ts"
	},
	"dependencies": {
		"koa":                          "^2.16.1",
		"@koa/router":                  "^13.1.0",
		"koa-bodyparser":               "^4.4.1",
		"@fonderie-js/adapter-koa":     "../../packages/adapter-koa",
		"@fonderie-js/auth":            "../../packages/auth",
		"@fonderie-js/core":            "../../packages/core",
		"@fonderie-js/events":          "../../packages/events",
		"@fonderie-js/store":           "../../packages/store"
	},
	"devDependencies": {
		"@types/koa":              "^2.15.0",
		"@types/koa-bodyparser":   "^4.3.12",
		"@types/koa__router":      "^12.0.4",
		"@types/node":             "^25.6.2",
		"tsx":                     "^4.21.0"
	}
}
