{
	"name": "@fonderie/sdk",
	"private": true,
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"build": "turbo build",
		"dev": "npm run dev --workspaces --if-present",
		"typecheck": "turbo typecheck",
		"test": "turbo test",
		"lint": "biome lint .",
		"format": "biome format --write .",
		"check": "biome check --write .",
		"changeset": "changeset",
		"version": "changeset version",
		"release": "npm run build && changeset publish",
		"docs:signatures": "node scripts/generate-signatures.mjs && node scripts/generate-outcomes.mjs",
		"docs:brain": "node scripts/generate-brain.mjs",
		"brain:serve": "node scripts/brain-serve.mjs",
		"brain:test": "node scripts/brain-serve.test.mjs",
		"audit:validation": "node scripts/audit-validation.mjs"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.0.0",
		"@changesets/cli": "^2.31.0",
		"turbo": "^2.10.4"
	},
	"license": "MIT",
	"packageManager": "npm@11.16.0"
}
